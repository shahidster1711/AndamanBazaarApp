{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@andaman-planner/shared": ["../../packages/shared/src/index.ts"],
      "@andaman-planner/ui": ["../../packages/ui/src/index.ts"],
      "@andaman-planner/supabase": ["../../packages/supabase/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
